            // LEFT: shader + fps
            VStack(alignment: .leading, spacing: 4) {
                Text(shaderManager.currentDisplayName.uppercased())
                    .font(.caption.bold())

                if mediaRecorder.isRecording {
                    // Во время записи показываем оба FPS
