            return [.wide]
        }
        
        var result: [ZoomPreset] = []
        
        if cameraManager.hasUltraWideForUI {
            result.append(.ultraWide)
        }
        
        result.append(.wide)
        
        if cameraManager.hasTelephotoForUI {
            result.append(.telephoto)
        }
        
        return result
    }
