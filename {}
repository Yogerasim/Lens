struct ZoomPresetRow: View {
    
    @ObservedObject var cameraManager: CameraManager
    
    var body: some View {
        HStack(spacing: 14) {
            ForEach(availablePresets, id: \.self) { preset in
                let isSelected = isPresetSelected(preset)
                
                Button {
                    withAnimation(.easeInOut(duration: 0.2)) {
