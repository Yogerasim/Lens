        let current = cameraManager.currentZoomFactor
        
        switch preset {
        case .ultraWide:
            return abs(current - 0.5) < 0.12
        case .wide:
            return abs(current - 1.0) < 0.16
        case .telephoto:
            return abs(current - 2.0) < 0.22
        }
