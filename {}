                    }
                } label: {
                    Text(preset.title)
                        .font(.subheadline.bold())
                        .foregroundColor(isSelected ? .white : .white.opacity(0.75))
                        .glassChip(isSelected: isSelected)
                }
                .buttonStyle(.plain)
            }
        }
    }
    
